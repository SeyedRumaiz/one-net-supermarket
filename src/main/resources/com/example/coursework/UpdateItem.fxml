                                        <Font name="Baskerville" size="16.0" />
                                    </font>
                                </Label>
                                <TextField fx:id="updatingField" maxWidth="-Infinity" onAction="#validate" translateY="-50.0" GridPane.columnIndex="1" GridPane.halignment="CENTER" GridPane.hgrow="ALWAYS" GridPane.rowIndex="1" GridPane.valignment="CENTER" GridPane.vgrow="ALWAYS" />
                                <Label fx:id="errorLabel" textFill="#ff4848" translateX="180.0" GridPane.columnIndex="1" GridPane.rowIndex="1">
                                    <font>
                                        <Font size="16.0" />
                                    </font>
                                </Label>
                            </children>
                        </GridPane>
                    </children>
                </HBox>
            </children>
        </VBox>
    </center>

</BorderPane>
